{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev:vercel",
  "crons": [
    {
      "path": "/api/monitor/chatbot",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/ticket/sla/sweep",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/warranty/expiry/sweep",
      "schedule": "0 9 * * *"
    }
  ]
}
