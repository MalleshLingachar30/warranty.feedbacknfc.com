generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationType {
  manufacturer
  distributor
  service_center
  retailer
}

enum SubscriptionTier {
  pilot
  starter
  professional
  enterprise
}

enum UserRole {
  super_admin
  manufacturer_admin
  service_center_admin
  technician
  customer
}

enum StickerType {
  qr_only
  nfc_qr
  nfc_only
}

enum StickerVariant {
  standard
  high_temp
  premium
}

enum StickerStatus {
  unallocated
  allocated
  bound
  activated
  deactivated
}

enum WarrantyStatus {
  pending_activation
  active
  expired
  extended
  voided
}

enum IssueSeverity {
  low
  medium
  high
  critical
}

enum AssignmentMethod {
  ai_auto
  manual
  escalated
}

enum TicketStatus {
  reported
  assigned
  technician_enroute
  work_in_progress
  pending_confirmation
  resolved
  reopened
  escalated
  closed
}

enum TicketLiveTrackingState {
  inactive
  waiting_for_location
  enroute
  on_site
  paused
  stopped
}

enum ClaimType {
  warranty_repair
  warranty_replacement
  extended_warranty
  goodwill
}

enum ClaimStatus {
  auto_generated
  submitted
  under_review
  approved
  rejected
  disputed
  paid
  closed
}

enum StickerAllocationType {
  bulk_bind
  reserve_only
}

enum StickerScanSource {
  qr
  nfc
  unknown
}

enum ActivationMode {
  plug_and_play
  installation_driven
}

enum InstallationOwnershipMode {
  manufacturer_only
  dealer_allowed
}

enum ActivationTrigger {
  self_activation
  installation_report_submission
}

enum CustomerCreationMode {
  on_activation
  on_installation
}

enum PartTraceabilityMode {
  none
  pack_or_kit
  unit_scan_mandatory
}

enum SmallPartTrackingMode {
  individual
  pack_level
  kit_level
  pack_or_kit
}

enum AssetProductClass {
  main_product
  spare_part
  small_part
  kit
  pack
}

enum AssetLifecycleState {
  generated
  packed
  sold_pending_installation
  installation_scheduled
  installation_in_progress
  active
  consumed
  retired
  voided
}

enum TagClass {
  unit_service
  carton_registration
  component_unit
  small_part_batch
  kit_parent
  pack_parent
}

enum TagSymbology {
  qr
  data_matrix
  nfc_uri
}

enum AssetTagStatus {
  generated
  printed
  encoded
  active
  voided
}

enum TagViewerPolicy {
  public
  owner_only
  technician_admin
  warehouse_admin
}

model Organization {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String           @db.VarChar(255)
  type                  OrganizationType
  slug                  String?          @unique @db.VarChar(100)
  logoUrl               String?          @map("logo_url")
  address               String?
  city                  String?          @db.VarChar(100)
  state                 String?          @db.VarChar(100)
  country               String           @default("IN") @db.VarChar(50)
  pincode               String?          @db.VarChar(10)
  gstNumber             String?          @map("gst_number") @db.VarChar(20)
  contactEmail          String?          @map("contact_email") @db.VarChar(255)
  contactPhone          String?          @map("contact_phone") @db.VarChar(20)
  settings              Json             @default(dbgenerated("'{}'::jsonb"))
  subscriptionTier      SubscriptionTier @default(pilot) @map("subscription_tier")
  subscriptionExpiresAt DateTime?        @map("subscription_expires_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  users                User[]
  productModels        ProductModel[]
  allocatedStickers    Sticker[]            @relation("AllocatedOrganization")
  products             Product[]
  serviceCenters       ServiceCenter[]
  manufacturerClaims   WarrantyClaim[]      @relation("ManufacturerOrganizationClaims")
  serviceCenterClaims  WarrantyClaim[]      @relation("ServiceCenterOrganizationClaims")
  stickerAllocations   StickerAllocation[]
  assetIdentities      AssetIdentity[]
  tagGenerationBatches TagGenerationBatch[]

  @@map("organizations")
}

model User {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId            String   @unique @map("clerk_id") @db.VarChar(255)
  organizationId     String?  @map("organization_id") @db.Uuid
  email              String?  @db.VarChar(255)
  phone              String?  @db.VarChar(20)
  name               String?  @db.VarChar(255)
  role               UserRole
  languagePreference String   @default("en") @map("language_preference") @db.VarChar(5)
  isActive           Boolean  @default(true) @map("is_active")
  metadata           Json     @default(dbgenerated("'{}'::jsonb"))
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization                Organization?        @relation(fields: [organizationId], references: [id])
  technicianProfile           Technician?
  reportedTickets             Ticket[]             @relation("ReportedTickets")
  approvedClaims              WarrantyClaim[]      @relation("ClaimApprover")
  timelineEvents              TicketTimeline[]     @relation("TimelineActor")
  stickerAllocations          StickerAllocation[]  @relation("AllocatedByUser")
  createdTagGenerationBatches TagGenerationBatch[] @relation("TagGenerationBatchCreator")
  customerAssetIdentities     AssetIdentity[]      @relation("AssetIdentityCustomer")
  customerProducts            Product[]            @relation("CustomerProducts")
  scanLogs                    ScanLog[]            @relation("ScanLogActor")

  @@map("users")
}

model ChatLead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String   @unique @default(dbgenerated("gen_random_uuid()")) @map("session_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String   @db.VarChar(32)
  company   String   @db.VarChar(255)
  country   String   @db.VarChar(100)
  language  String   @db.VarChar(100)
  userType  String   @map("user_type") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("chat_leads")
}

model EndpointMonitorState {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checkName           String    @unique @map("check_name") @db.VarChar(100)
  status              String    @default("healthy") @db.VarChar(20)
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastCheckedAt       DateTime? @map("last_checked_at")
  lastSuccessAt       DateTime? @map("last_success_at")
  lastFailureAt       DateTime? @map("last_failure_at")
  lastAlertedAt       DateTime? @map("last_alerted_at")
  lastResolvedAt      DateTime? @map("last_resolved_at")
  lastError           String?   @map("last_error")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("endpoint_monitor_states")
}

model ProductModel {
  id                              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                  String                    @map("organization_id") @db.Uuid
  name                            String                    @db.VarChar(255)
  category                        String                    @db.VarChar(100)
  subCategory                     String?                   @map("sub_category") @db.VarChar(100)
  modelNumber                     String?                   @map("model_number") @db.VarChar(100)
  description                     String?
  imageUrl                        String?                   @map("image_url")
  warrantyDurationMonths          Int                       @default(12) @map("warranty_duration_months")
  extendedWarrantyAvailable       Boolean                   @default(false) @map("extended_warranty_available")
  extendedWarrantyMonths          Int?                      @map("extended_warranty_months")
  specifications                  Json                      @default(dbgenerated("'{}'::jsonb"))
  commonIssues                    Json                      @default(dbgenerated("'[]'::jsonb")) @map("common_issues")
  requiredSkills                  String[]                  @default([]) @map("required_skills")
  partsCatalog                    Json                      @default(dbgenerated("'[]'::jsonb")) @map("parts_catalog")
  activationMode                  ActivationMode            @default(plug_and_play) @map("activation_mode")
  installationOwnershipMode       InstallationOwnershipMode @default(manufacturer_only) @map("installation_ownership_mode")
  installationRequired            Boolean                   @default(false) @map("installation_required")
  activationTrigger               ActivationTrigger         @default(self_activation) @map("activation_trigger")
  customerCreationMode            CustomerCreationMode      @default(on_activation) @map("customer_creation_mode")
  allowCartonSaleRegistration     Boolean                   @default(true) @map("allow_carton_sale_registration")
  allowUnitSelfActivation         Boolean                   @default(true) @map("allow_unit_self_activation")
  partTraceabilityMode            PartTraceabilityMode      @default(none) @map("part_traceability_mode")
  smallPartTrackingMode           SmallPartTrackingMode     @default(individual) @map("small_part_tracking_mode")
  customerAcknowledgementRequired Boolean                   @default(false) @map("customer_acknowledgement_required")
  installationChecklistTemplate   Json                      @default(dbgenerated("'[]'::jsonb")) @map("installation_checklist_template")
  commissioningTemplate           Json                      @default(dbgenerated("'[]'::jsonb")) @map("commissioning_template")
  requiredPhotoPolicy             Json                      @default(dbgenerated("'{}'::jsonb")) @map("required_photo_policy")
  requiredGeoCapture              Boolean                   @default(false) @map("required_geo_capture")
  defaultInstallerSkillTags       String[]                  @default([]) @map("default_installer_skill_tags")
  includedKitDefinition           Json                      @default(dbgenerated("'{}'::jsonb")) @map("included_kit_definition")
  createdAt                       DateTime                  @default(now()) @map("created_at")
  updatedAt                       DateTime                  @updatedAt @map("updated_at")

  organization         Organization         @relation(fields: [organizationId], references: [id])
  products             Product[]
  stickerAllocations   StickerAllocation[]
  assetIdentities      AssetIdentity[]
  tagGenerationBatches TagGenerationBatch[]

  @@map("product_models")
}

model TagGenerationBatch {
  id                            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                String            @map("organization_id") @db.Uuid
  productModelId                String            @map("product_model_id") @db.Uuid
  productClass                  AssetProductClass @map("product_class")
  quantity                      Int
  serialPrefix                  String?           @map("serial_prefix") @db.VarChar(100)
  serialStart                   String?           @map("serial_start") @db.VarChar(100)
  serialEnd                     String?           @map("serial_end") @db.VarChar(100)
  includeCartonRegistrationTags Boolean           @default(false) @map("include_carton_registration_tags")
  defaultSymbology              TagSymbology      @map("default_symbology")
  outputProfile                 Json              @default(dbgenerated("'{}'::jsonb")) @map("output_profile")
  createdById                   String            @map("created_by_id") @db.Uuid
  createdAt                     DateTime          @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  productModel ProductModel    @relation(fields: [productModelId], references: [id])
  createdBy    User            @relation("TagGenerationBatchCreator", fields: [createdById], references: [id])
  assets       AssetIdentity[]
  tags         AssetTag[]

  @@index([organizationId, createdAt], map: "idx_tag_generation_batches_org_created")
  @@index([productModelId], map: "idx_tag_generation_batches_model")
  @@map("tag_generation_batches")
}

model AssetIdentity {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicCode           String              @unique @map("public_code") @db.VarChar(80)
  organizationId       String              @map("organization_id") @db.Uuid
  productModelId       String              @map("product_model_id") @db.Uuid
  productClass         AssetProductClass   @map("product_class")
  serialNumber         String?             @map("serial_number") @db.VarChar(255)
  batchCode            String?             @map("batch_code") @db.VarChar(120)
  lifecycleState       AssetLifecycleState @default(generated) @map("lifecycle_state")
  warrantyState        WarrantyStatus?     @map("warranty_state")
  customerId           String?             @map("customer_id") @db.Uuid
  installationDate     DateTime?           @map("installation_date")
  installationLocation Json?               @map("installation_location")
  rootMainAssetId      String?             @map("root_main_asset_id") @db.Uuid
  metadata             Json                @default(dbgenerated("'{}'::jsonb"))
  generationBatchId    String?             @map("generation_batch_id") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  organization    Organization        @relation(fields: [organizationId], references: [id])
  productModel    ProductModel        @relation(fields: [productModelId], references: [id])
  customer        User?               @relation("AssetIdentityCustomer", fields: [customerId], references: [id])
  rootMainAsset   AssetIdentity?      @relation("AssetRootLineage", fields: [rootMainAssetId], references: [id])
  childAssets     AssetIdentity[]     @relation("AssetRootLineage")
  generationBatch TagGenerationBatch? @relation(fields: [generationBatchId], references: [id])
  tags            AssetTag[]

  @@index([organizationId, productClass], map: "idx_asset_identities_org_class")
  @@index([organizationId, productModelId], map: "idx_asset_identities_org_model")
  @@index([serialNumber], map: "idx_asset_identities_serial")
  @@index([generationBatchId], map: "idx_asset_identities_batch")
  @@map("asset_identities")
}

model AssetTag {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicCode        String          @unique @map("public_code") @db.VarChar(100)
  assetId           String          @map("asset_id") @db.Uuid
  generationBatchId String?         @map("generation_batch_id") @db.Uuid
  tagClass          TagClass        @map("tag_class")
  symbology         TagSymbology    @map("symbology")
  status            AssetTagStatus  @default(generated)
  materialVariant   StickerVariant  @default(standard) @map("material_variant")
  printSizeMm       Int?            @map("print_size_mm")
  encodedValue      String          @map("encoded_value")
  viewerPolicy      TagViewerPolicy @default(public) @map("viewer_policy")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  asset           AssetIdentity       @relation(fields: [assetId], references: [id])
  generationBatch TagGenerationBatch? @relation(fields: [generationBatchId], references: [id])

  @@index([assetId], map: "idx_asset_tags_asset")
  @@index([generationBatchId], map: "idx_asset_tags_batch")
  @@index([symbology, status], map: "idx_asset_tags_symbology_status")
  @@map("asset_tags")
}

model Sticker {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stickerNumber    Int            @unique @map("sticker_number")
  stickerSerial    String         @unique @map("sticker_serial") @db.VarChar(20)
  type             StickerType    @default(qr_only)
  variant          StickerVariant @default(standard)
  status           StickerStatus  @default(unallocated)
  allocatedToOrgId String?        @map("allocated_to_org") @db.Uuid
  batchId          String?        @map("batch_id") @db.VarChar(50)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  allocatedToOrg Organization? @relation("AllocatedOrganization", fields: [allocatedToOrgId], references: [id])
  product        Product?
  tickets        Ticket[]

  @@index([stickerNumber], map: "idx_stickers_number")
  @@map("stickers")
}

model Product {
  id                      String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stickerId               String         @unique @map("sticker_id") @db.Uuid
  productModelId          String         @map("product_model_id") @db.Uuid
  organizationId          String         @map("organization_id") @db.Uuid
  serialNumber            String?        @map("serial_number") @db.VarChar(255)
  manufactureDate         DateTime?      @map("manufacture_date") @db.Date
  saleDate                DateTime?      @map("sale_date") @db.Date
  installationDate        DateTime?      @map("installation_date") @db.Date
  warrantyStartDate       DateTime?      @map("warranty_start_date")
  warrantyEndDate         DateTime?      @map("warranty_end_date")
  warrantyStatus          WarrantyStatus @default(pending_activation) @map("warranty_status")
  extendedWarrantyEndDate DateTime?      @map("extended_warranty_end_date")
  customerId              String?        @map("customer_id") @db.Uuid
  customerName            String?        @map("customer_name") @db.VarChar(255)
  customerPhone           String?        @map("customer_phone") @db.VarChar(20)
  customerPhoneVerified   Boolean        @default(false) @map("customer_phone_verified")
  customerEmail           String?        @map("customer_email") @db.VarChar(255)
  customerAddress         String?        @map("customer_address")
  customerCity            String?        @map("customer_city") @db.VarChar(100)
  customerState           String?        @map("customer_state") @db.VarChar(100)
  customerPincode         String?        @map("customer_pincode") @db.VarChar(10)
  activatedVia            String?        @map("activated_via") @db.VarChar(20)
  activatedAtLocation     String?        @map("activated_at_location") @db.VarChar(255)
  installationLocation    Json?          @map("installation_location")
  metadata                Json           @default(dbgenerated("'{}'::jsonb"))
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  sticker      Sticker         @relation(fields: [stickerId], references: [id])
  productModel ProductModel    @relation(fields: [productModelId], references: [id])
  organization Organization    @relation(fields: [organizationId], references: [id])
  customer     User?           @relation("CustomerProducts", fields: [customerId], references: [id])
  tickets      Ticket[]
  claims       WarrantyClaim[]
  otpSessions  OtpSession[]
  scanLogs     ScanLog[]

  @@index([warrantyStatus, warrantyEndDate], map: "idx_products_warranty")
  @@map("products")
}

model ServiceCenter {
  id                         String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId             String                @map("organization_id") @db.Uuid
  name                       String                @db.VarChar(255)
  address                    String?
  city                       String?               @db.VarChar(100)
  state                      String?               @db.VarChar(100)
  pincode                    String?               @db.VarChar(10)
  phone                      String?               @db.VarChar(20)
  email                      String?               @db.VarChar(255)
  location                   Unsupported("point")?
  serviceRadiusKm            Int                   @default(50) @map("service_radius_km")
  supportedCategories        String[]              @default([]) @map("supported_categories")
  manufacturerAuthorizations String[]              @default([]) @map("manufacturer_authorizations") @db.Uuid
  operatingHours             Json?                 @map("operating_hours")
  isActive                   Boolean               @default(true) @map("is_active")
  rating                     Decimal               @default(0.00) @db.Decimal(3, 2)
  totalJobsCompleted         Int                   @default(0) @map("total_jobs_completed")
  averageResolutionHours     Decimal?              @map("average_resolution_hours") @db.Decimal(6, 2)
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id])
  technicians     Technician[]
  assignedTickets Ticket[]     @relation("AssignedServiceCenterTickets")

  @@index([organizationId], map: "idx_service_centers_organization")
  @@index([location], type: Gist, map: "idx_service_centers_location")
  @@map("service_centers")
}

model Technician {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String                @unique @map("user_id") @db.Uuid
  serviceCenterId    String                @map("service_center_id") @db.Uuid
  name               String                @db.VarChar(255)
  phone              String                @db.VarChar(20)
  skills             String[]
  certifications     Json                  @default(dbgenerated("'[]'::jsonb"))
  isAvailable        Boolean               @default(true) @map("is_available")
  currentLocation    Unsupported("point")? @map("current_location")
  maxConcurrentJobs  Int                   @default(3) @map("max_concurrent_jobs")
  activeJobCount     Int                   @default(0) @map("active_job_count")
  rating             Decimal               @default(0.00) @db.Decimal(3, 2)
  totalJobsCompleted Int                   @default(0) @map("total_jobs_completed")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  user            User               @relation(fields: [userId], references: [id])
  serviceCenter   ServiceCenter      @relation(fields: [serviceCenterId], references: [id])
  assignedTickets Ticket[]           @relation("AssignedTechnicianTickets")
  liveStatuses    TicketLiveStatus[]

  @@index([serviceCenterId], map: "idx_technicians_service_center")
  @@map("technicians")
}

model Ticket {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketNumber            String           @unique @map("ticket_number") @db.VarChar(20)
  productId               String           @map("product_id") @db.Uuid
  stickerId               String           @map("sticker_id") @db.Uuid
  reportedByUserId        String?          @map("reported_by_user_id") @db.Uuid
  reportedByName          String?          @map("reported_by_name") @db.VarChar(255)
  reportedByPhone         String           @map("reported_by_phone") @db.VarChar(20)
  issueCategory           String?          @map("issue_category") @db.VarChar(100)
  issueDescription        String           @map("issue_description")
  issueSeverity           IssueSeverity    @default(medium) @map("issue_severity")
  issuePhotos             String[]         @default([]) @map("issue_photos")
  assignedServiceCenterId String?          @map("assigned_service_center_id") @db.Uuid
  assignedTechnicianId    String?          @map("assigned_technician_id") @db.Uuid
  assignmentMethod        AssignmentMethod @default(ai_auto) @map("assignment_method")
  assignmentNotes         String?          @map("assignment_notes")
  reportedAt              DateTime         @default(now()) @map("reported_at")
  assignedAt              DateTime?        @map("assigned_at")
  technicianStartedAt     DateTime?        @map("technician_started_at")
  technicianCompletedAt   DateTime?        @map("technician_completed_at")
  customerConfirmedAt     DateTime?        @map("customer_confirmed_at")
  customerServiceRating   Int?             @map("customer_service_rating")
  closedAt                DateTime?        @map("closed_at")
  status                  TicketStatus     @default(reported)
  resolutionNotes         String?          @map("resolution_notes")
  resolutionPhotos        String[]         @default([]) @map("resolution_photos")
  partsUsed               Json             @default(dbgenerated("'[]'::jsonb")) @map("parts_used")
  laborHours              Decimal?         @map("labor_hours") @db.Decimal(4, 2)
  claimId                 String?          @unique @map("claim_id") @db.Uuid
  isWarrantyCovered       Boolean          @default(true) @map("is_warranty_covered")
  slaResponseDeadline     DateTime?        @map("sla_response_deadline")
  slaResolutionDeadline   DateTime?        @map("sla_resolution_deadline")
  slaBreached             Boolean          @default(false) @map("sla_breached")
  escalationLevel         Int              @default(0) @map("escalation_level")
  escalatedAt             DateTime?        @map("escalated_at")
  escalationReason        String?          @map("escalation_reason")
  metadata                Json             @default(dbgenerated("'{}'::jsonb"))
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")

  product               Product           @relation(fields: [productId], references: [id])
  sticker               Sticker           @relation(fields: [stickerId], references: [id])
  reportedByUser        User?             @relation("ReportedTickets", fields: [reportedByUserId], references: [id])
  assignedServiceCenter ServiceCenter?    @relation("AssignedServiceCenterTickets", fields: [assignedServiceCenterId], references: [id])
  assignedTechnician    Technician?       @relation("AssignedTechnicianTickets", fields: [assignedTechnicianId], references: [id])
  liveStatus            TicketLiveStatus?
  timelineEntries       TicketTimeline[]
  claimById             WarrantyClaim?    @relation("TicketClaimPointer", fields: [claimId], references: [id])
  claim                 WarrantyClaim?    @relation("TicketToWarrantyClaim")

  @@index([status], map: "idx_tickets_status")
  @@index([productId], map: "idx_tickets_product")
  @@index([assignedTechnicianId], map: "idx_tickets_technician")
  @@index([assignedServiceCenterId], map: "idx_tickets_service_center")
  @@map("tickets")
}

model TicketLiveStatus {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId               String                  @unique @map("ticket_id") @db.Uuid
  technicianId           String?                 @map("technician_id") @db.Uuid
  state                  TicketLiveTrackingState @default(inactive)
  serviceAnchorLatitude  Decimal?                @map("service_anchor_latitude") @db.Decimal(9, 6)
  serviceAnchorLongitude Decimal?                @map("service_anchor_longitude") @db.Decimal(9, 6)
  technicianLatitude     Decimal?                @map("technician_latitude") @db.Decimal(9, 6)
  technicianLongitude    Decimal?                @map("technician_longitude") @db.Decimal(9, 6)
  technicianAccuracyM    Decimal?                @map("technician_accuracy_m") @db.Decimal(8, 2)
  distanceKm             Decimal?                @map("distance_km") @db.Decimal(6, 2)
  etaMinutes             Int?                    @map("eta_minutes")
  lastUpdatedAt          DateTime?               @map("last_updated_at")
  startedAt              DateTime?               @map("started_at")
  arrivedAt              DateTime?               @map("arrived_at")
  pausedAt               DateTime?               @map("paused_at")
  stoppedAt              DateTime?               @map("stopped_at")
  metadata               Json                    @default(dbgenerated("'{}'::jsonb"))
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  ticket     Ticket      @relation(fields: [ticketId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])

  @@index([state], map: "idx_ticket_live_status_state")
  @@index([technicianId], map: "idx_ticket_live_status_technician")
  @@map("ticket_live_status")
}

model WarrantyClaim {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  claimNumber         String      @unique @map("claim_number") @db.VarChar(20)
  ticketId            String      @unique @map("ticket_id") @db.Uuid
  productId           String      @map("product_id") @db.Uuid
  manufacturerOrgId   String      @map("manufacturer_org_id") @db.Uuid
  serviceCenterOrgId  String      @map("service_center_org_id") @db.Uuid
  claimType           ClaimType   @default(warranty_repair) @map("claim_type")
  partsCost           Decimal     @default(0.00) @map("parts_cost") @db.Decimal(10, 2)
  laborCost           Decimal     @default(0.00) @map("labor_cost") @db.Decimal(10, 2)
  totalClaimAmount    Decimal     @default(0.00) @map("total_claim_amount") @db.Decimal(10, 2)
  currency            String      @default("INR") @db.VarChar(3)
  documentation       Json        @default(dbgenerated("'{}'::jsonb"))
  documentationPdfUrl String?     @map("documentation_pdf_url")
  status              ClaimStatus @default(auto_generated)
  rejectionReason     String?     @map("rejection_reason")
  approvedAmount      Decimal?    @map("approved_amount") @db.Decimal(10, 2)
  approvedById        String?     @map("approved_by") @db.Uuid
  approvedAt          DateTime?   @map("approved_at")
  paymentReference    String?     @map("payment_reference") @db.VarChar(255)
  paidAt              DateTime?   @map("paid_at")
  paymentMethod       String?     @map("payment_method") @db.VarChar(50)
  submittedAt         DateTime?   @map("submitted_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  ticket           Ticket       @relation("TicketToWarrantyClaim", fields: [ticketId], references: [id])
  ticketPointer    Ticket?      @relation("TicketClaimPointer")
  product          Product      @relation(fields: [productId], references: [id])
  manufacturerOrg  Organization @relation("ManufacturerOrganizationClaims", fields: [manufacturerOrgId], references: [id])
  serviceCenterOrg Organization @relation("ServiceCenterOrganizationClaims", fields: [serviceCenterOrgId], references: [id])
  approvedBy       User?        @relation("ClaimApprover", fields: [approvedById], references: [id])

  @@index([serviceCenterOrgId], map: "idx_warranty_claims_service_center_org")
  @@map("warranty_claims")
}

model TicketTimeline {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId         String   @map("ticket_id") @db.Uuid
  eventType        String   @map("event_type") @db.VarChar(50)
  eventDescription String?  @map("event_description")
  actorUserId      String?  @map("actor_user_id") @db.Uuid
  actorRole        String?  @map("actor_role") @db.VarChar(50)
  actorName        String?  @map("actor_name") @db.VarChar(255)
  metadata         Json     @default(dbgenerated("'{}'::jsonb"))
  createdAt        DateTime @default(now()) @map("created_at")

  ticket    Ticket @relation(fields: [ticketId], references: [id])
  actorUser User?  @relation("TimelineActor", fields: [actorUserId], references: [id])

  @@index([ticketId, createdAt], map: "idx_timeline_ticket")
  @@map("ticket_timeline")
}

model StickerAllocation {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String                @map("organization_id") @db.Uuid
  stickerStartNumber    Int                   @map("sticker_start_number")
  stickerEndNumber      Int                   @map("sticker_end_number")
  totalCount            Int                   @map("total_count")
  productModelId        String?               @map("product_model_id") @db.Uuid
  allocationType        StickerAllocationType @default(bulk_bind) @map("allocation_type")
  applianceSerialPrefix String?               @map("appliance_serial_prefix") @db.VarChar(50)
  applianceSerialStart  String?               @map("appliance_serial_start") @db.VarChar(100)
  applianceSerialEnd    String?               @map("appliance_serial_end") @db.VarChar(100)
  includeCartonQr       Boolean               @default(true) @map("include_carton_qr")
  allocatedById         String?               @map("allocated_by") @db.Uuid
  allocatedAt           DateTime              @default(now()) @map("allocated_at")
  notes                 String?
  createdAt             DateTime              @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  productModel ProductModel? @relation(fields: [productModelId], references: [id])
  allocatedBy  User?         @relation("AllocatedByUser", fields: [allocatedById], references: [id])

  @@map("sticker_allocations")
}

model StickerScanEvent {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stickerId      String            @map("sticker_id") @db.Uuid
  stickerNumber  Int               @map("sticker_number")
  organizationId String?           @map("organization_id") @db.Uuid
  source         StickerScanSource @default(unknown)
  userAgent      String?           @map("user_agent")
  scannedAt      DateTime          @default(now()) @map("scanned_at")

  @@index([organizationId, scannedAt], map: "idx_sticker_scans_org_time")
  @@index([stickerId, scannedAt], map: "idx_sticker_scans_sticker_time")
  @@index([stickerNumber], map: "idx_sticker_scans_number")
  @@map("sticker_scan_events")
}

model OtpSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone            String    @db.VarChar(20)
  productId        String    @map("product_id") @db.Uuid
  purpose          String    @db.VarChar(30)
  otpCode          String    @map("otp_code") @db.VarChar(6)
  otpExpiresAt     DateTime  @map("otp_expires_at")
  verified         Boolean   @default(false)
  sessionToken     String?   @unique(map: "otp_sessions_session_token_key") @map("session_token") @db.VarChar(255)
  sessionExpiresAt DateTime? @map("session_expires_at")
  attempts         Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([phone, productId], map: "idx_otp_sessions_phone_product")
  @@map("otp_sessions")
}

model ScanLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stickerNumber Int      @map("sticker_number")
  productId     String?  @map("product_id") @db.Uuid
  scanSource    String?  @map("scan_source") @db.VarChar(10)
  scanContext   String?  @map("scan_context") @db.VarChar(20)
  viewerType    String   @map("viewer_type") @db.VarChar(30)
  userId        String?  @map("user_id") @db.Uuid
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent")
  actionTaken   String?  @map("action_taken") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")

  product Product? @relation(fields: [productId], references: [id])
  user    User?    @relation("ScanLogActor", fields: [userId], references: [id])

  @@index([stickerNumber, createdAt], map: "idx_scan_log_sticker")
  @@map("scan_log")
}
